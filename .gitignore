# Matriarch Unified Root Structure .gitignore

# 1. Block everything at the root by default
/*

# 2. Whitelist project-critical files
!/.gitignore
!/package.json
!/package-lock.json
!/index.html
!/vite.config.ts
!/tsconfig.json
!/tsconfig.app.json
!/tsconfig.node.json
!/vercel.json
!/README.md

# 3. Whitelist project-critical folders
!/src/
!/public/
!/backend/

# 4. Ignore build artifacts & dependencies within whitelisted folders
**/node_modules
**/dist
**/build
**/.next
**/.vercel
**/.venv
**/__pycache__
**/*.pyc
**/.env
**/.env.local
**/.DS_Store
